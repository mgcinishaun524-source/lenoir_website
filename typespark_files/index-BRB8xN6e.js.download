),Ug=[{title:"Community First",desc:"Every decision we make starts with the communities we serve. We listen before we act, and we build alongside — not on top of — the people we partner with."},{title:"Education as a Right",desc:"We believe access to technology and quality education is not a privilege for the few — it is a fundamental right for every child, everywhere."},{title:"Radical Transparency",desc:"We publish our impact, our finances, and our shortcomings openly. Trust is built through honesty, and we take that responsibility seriously."},{title:"Shared Experience",desc:"Our founder walked the same path as the children we serve. That lived experience shapes every programme, every partnership, and every pound we spend."}];function Lg(){return u.jsxs("div",{className:"min-h-screen bg-[#F5F6F8] text-[#2E3F4D] font-sans overflow-x-hidden",children:[u.jsx(Et,{}),u.jsxs("section",{className:"relative pt-20 bg-[#131E25] overflow-hidden",children:[u.jsxs("div",{className:"absolute inset-0 z-0",children:[u.jsx("img",{src:"https://static.wixstatic.com/media/a7af79_e1c02a1ffefa4065b726989f317bb22b~mv2.jpg",alt:"Children learning",className:"w-full h-full object-cover opacity-20"}),u.jsx("div",{className:"absolute inset-0 bg-gradient-to-b from-[#131E25]/80 to-[#131E25]"})]}),u.jsxs("div",{className:"relative z-10 max-w-7xl mx-auto px-6 py-28 lg:py-36",children:[u.jsx("p",{className:"text-[#C4553A] font-medium uppercase tracking-widest text-sm mb-4",children:"About Us"}),u.jsx("h1",{className:"font-serif text-5xl lg:text-6xl font-bold text-[#F5F6F8] leading-[1.1] mb-6 max-w-3xl",children:"About The LeNoir Foundation"}),u.jsx("p",{className:"text-xl text-[#C8D5E0] max-w-2xl leading-relaxed",children:"Our vision is to make e-learning technology accessible to all students and members of their communities."})]})]}),u.jsx("section",{className:"py-24 bg-[#F5F6F8]",children:u.jsx("div",{className:"max-w-7xl mx-auto px-6",children:u.jsxs("div",{className:"grid lg:grid-cols-2 gap